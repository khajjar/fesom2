! This is the namelist file for model general configuration

&modelname
runid='fesom'
/

&timestep
step_per_day=144 !96 !96 !72 !72 !45 !72 !96
run_length=12 !62 !62 !62 !28
run_length_unit='m'		! y, m, d, s
/

&clockinit              ! the model starts at
timenew=0.0
daynew=1
yearnew=1957
/

&paths
MeshPath='/work/bb1143/b382132/model/fesom2/FESOM2_multi-year/mesh/TRAC/'   !'/work/bb1143/b382132/model/fesom2/FESOM2_multi-year/mesh/core2/'
ClimateDataPath='/pool/data/AWICM/FESOM2/INITIAL/phc3.0/'
ResultPath='../result/'
/

&restart_log
restart_length=1        !only required for d,h,s cases,  y, m take 1
restart_length_unit='m' !output period: y,  d, h, s 
logfile_outfreq=960     !in logfile info. output frequency, # steps
/

&ale_def
which_ALE='zstar'       ! 'linfs','zlevel', 'zstar'
use_partial_cell=.true.
/

&geometry
cartesian=.false.
fplane=.false.
cyclic_length=360       ![degree]
rotated_grid=.true.     !option only valid for coupled model case now
force_rotation=.true.
alphaEuler=50.          ![degree] Euler angles, convention:
betaEuler=15.           ![degree] first around z, then around new x,
gammaEuler=-90.         ![degree] then around new z.
/

&calendar
include_fleapyear=.true.
/

&run_config
use_ice=.true.                  ! ocean+ice
use_cavity=.false.              !
use_cavity_partial_cell=.false. 
use_floatice = .false.
use_sw_pene=.true.
flag_warn_cflz=.false.
use_transit=.false.
anthro_transit=.false.
paleo_transit=.false.
length_transit=1009              
ti_start_transit=997
ifile_transit='/work/bb1143/b382132/model/fesom2/ocean_tracer_boundary/data.csv'
/

&machine
n_levels= 1
!n_part= 1          ! 432 number of partitions on each hierarchy level
!n_part= 4, 24, 36         ! 2304 number of partitions on each hierarchy level
n_part= 1152         ! 6144 number of partitions on each hierarchy level
/
